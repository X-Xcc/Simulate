# 忽略临时文件和缓存，但保留有用的模型和配置文件
# 注意：小白用户请保留 models/ 目录中的预训练模型文件

# Python缓存
__pycache__/
*.pyc
*.pyo

# IDE文件
.idea/
.vscode/settings.json
*.swp
*.swo

# 日志文件（保留重要的错误日志）
*.log

# 临时文件
temp/
*.tmp
*.bak

# 大文件（超过100MB的文件会被GitHub拒绝）
*.mp4
*.mov
*.avi
*.mkv
*.zip
*.rar
*.7z

# AI模型权重文件（如果太大可以忽略）
# weights/
# *.pt
# *.pth
# *.bin
# *.safetensors

# 运行结果（包含检测结果的目录）
# results/

# 构建产物
target/

# 系统文件
.DS_Store
Thumbs.db
